  lane :deliver_internal_framework do
    zip_path, spec_path = generate_internal_framework
    send_via_sftp(zip_path, Pathname.new('/nmsdk/test/ios') + zip_path.basename, true)
    sh "bundle exec pod repo push --verbose inomera #{spec_path}"
  end

  lane :deliver_framework do
    zip_path, spec_path = generate_framework
    send_via_sftp(zip_path, Pathname.new('/nmsdk/release/ios') + zip_path.basename)
  end

  lane :release_framework do
    zip_path, spec_path = generate_framework
    send_via_sftp(zip_path, Pathname.new('/nmsdk/release/ios') + zip_path.basename, true)
    sh "pwd"
    sh "pod trunk push --verbose #{spec_path}"
  end

  lane :generate_internal_framework do
    require 'cocoapods-core'
    spec = Pod::Specification.from_file(spec_file)
    package_name = "#{spec.name}-#{spec.version}"
    framework_dir = package_dir + "#{package_name}/"
    generated_spec_path = framework_dir + "#{spec.name}.podspec"
    framework_source = {:http => "https://release.netmera.com/test/ios/#{spec.version}.zip"}
    sh "bundle exec pod package --verbose --embedded --force --subspecs=#{spec.subspecs.map(&:base_name).join(',')} #{spec_file} '#{framework_source}'"
    sh "mv #{package_name} #{package_dir}"

    # zip framework
    sh "cd #{framework_dir} && zip -r -X -y #{spec.version}.zip #{spec.available_platforms.map(&:name).join(' ')}"
    sh "mv #{framework_dir}#{spec.version}.zip #{package_dir}"

    # return zip path
    [Pathname.new("#{package_dir}#{spec.version}.zip"), Pathname.new(generated_spec_path)]
  end

  lane :generate_framework do
    require 'cocoapods-core'
    spec = Pod::Specification.from_file(spec_file)
    package_name = "#{spec.name}-#{spec.version}"
    framework_dir = package_dir + "#{package_name}/"
    generated_spec_path = framework_dir + "#{spec.name}.podspec"
    framework_source = {:http => "https://release.netmera.com/release/ios/#{spec.version}.zip"}
    sh "bundle exec pod package --verbose --embedded --force --subspecs=#{spec.subspecs.map(&:base_name).join(',')} #{spec_file} '#{framework_source}'"
    sh "mv #{package_name} #{package_dir}"

    # zip framework
    sh "cd #{framework_dir} && zip -r -X -y #{spec.version}.zip #{spec.available_platforms.map(&:name).join(' ')}"
    sh "mv #{framework_dir}#{spec.version}.zip #{package_dir}"

    # return zip path
    [Pathname.new("#{package_dir}#{spec.version}.zip"), Pathname.new(generated_spec_path)]
  end
  
lane :upload_beta_amazon do

aws_s3(
# All of these are used to make Shenzhen's `ipa distribute:s3` command
access_key: ENV['S3_ACCESS_KEY'],               # Required from user (unless using aws_profile).
secret_access_key: ENV['S3_SECRET_ACCESS_KEY'], # Required from user (unless using aws_profile).
# aws_profile: ENV['AWS_PROFILE'],                 # Required from user (unless using access_key and secret_access_key)
bucket: ENV['S3_BUCKET'],                       # Required from user.
